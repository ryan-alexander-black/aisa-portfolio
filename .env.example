# Copy to .env.local for local dev, and add the same keys in Vercel → Project → Settings → Environment Variables.

# Resend API key (resend.com → API Keys). Required for the /operator-form route to send.
RESEND_API_KEY=

# Where intake submissions are emailed. Once ryanalexanderblack.com is verified in
# Resend you can set this to your Gmail directly. Defaults to ryanalexanderblack@gmail.com.
OPERATOR_FORM_TO=

# Optional: override the send-from identity. Must be on a domain verified in Resend.
# Defaults to: Ryan Alexander Black — Operator Intake <hello@ryanalexanderblack.com>
MAIL_FROM=
